---
// Hero — Research Center identity
---

<section class="hero" id="hero">
  <div class="hero-shape hero-shape-1" aria-hidden="true"></div>
  <div class="hero-shape hero-shape-2" aria-hidden="true"></div>

  <div class="container hero-content">
    <div class="hero-badge animate-on-scroll">
      <span class="badge-dot"></span>
      Research Center
    </div>

    <h1 class="hero-title animate-on-scroll">
      <span class="hero-title-main">EAI LAB</span>
      <span class="hero-title-sub">Embodied Intelligence<br />Research Center</span>
    </h1>

    <p class="hero-desc animate-on-scroll">
      Exploring how intelligent machines learn through physical interaction — perceiving, reasoning, and acting in the real world alongside humans.
    </p>

    <div class="hero-actions animate-on-scroll">
      <a href="#directions" class="btn btn-primary">
        <span>Research Directions</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="#impact" class="btn btn-ghost">Our Vision</a>
    </div>

    <div class="hero-focus animate-on-scroll">
      <span class="focus-pill">Manipulation</span>
      <span class="focus-pill">Locomotion</span>
      <span class="focus-pill">Perception</span>
      <span class="focus-pill">Railway AI</span>
      <span class="focus-pill">Field Robotics</span>
    </div>
  </div>

  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: calc(var(--nav-height) + 2rem) 0 4rem;
    z-index: 1;
    background: linear-gradient(180deg, #eef2f7 0%, #ffffff 60%);
  }

  .hero-shape {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-shape-1 {
    width: 500px;
    height: 500px;
    top: 5%;
    right: -8%;
    background: radial-gradient(circle, rgba(0, 120, 200, 0.05) 0%, transparent 70%);
    animation: float 10s ease-in-out infinite;
  }

  .hero-shape-2 {
    width: 350px;
    height: 350px;
    bottom: 15%;
    left: -3%;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.04) 0%, transparent 70%);
    animation: float 12s ease-in-out infinite reverse;
  }

  .hero-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.4rem 1rem;
    border: 1px solid var(--accent-dim);
    border-radius: 100px;
    background: var(--accent-light);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 6px var(--green);
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .hero-title-main {
    font-family: var(--font-body);
    font-size: clamp(3rem, 10vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text);
    line-height: 1;
  }

  .hero-title-sub {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    font-weight: 400;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .hero-desc {
    max-width: 560px;
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: all 0.25s;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: #005fa3;
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    color: #fff;
  }

  .btn-ghost {
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--text-secondary);
  }

  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }

  .hero-focus {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .focus-pill {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--glass-border);
    border-radius: 100px;
    background: var(--bg-secondary);
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .scroll-line {
    width: 2px;
    height: 32px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    border-radius: 1px;
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; height: 32px; }
    50% { opacity: 0.7; height: 40px; }
  }

  @media (max-width: 640px) {
    .hero { padding: calc(var(--nav-height) + 1rem) 0 3rem; }
  }
</style>
